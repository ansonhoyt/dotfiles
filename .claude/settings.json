{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:developers.openai.com)",
      "WebFetch(domain:google-gemini.github.io)",
      "WebFetch(domain:api.rubyonrails.org)",
      "WebFetch(domain:docs.ruby-lang.org)",
      "WebFetch(domain:rdoc.info)",
      "WebFetch(domain:rubydoc.info)",
      "WebFetch(domain:rubygems.org)",
      "WebFetch(domain:index.rubygems.org)",
      "WebFetch(domain:rubocop.org)",
      "WebFetch(domain:docs.rubocop.org)",
      "WebFetch(domain:rubyweekly.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:hotwired.dev)",
      "WebFetch(domain:hotwire.io)",
      "WebFetch(domain:native.hotwired.dev)",
      "WebFetch(domain:stimulus.hotwired.dev)",
      "WebFetch(domain:turbo.hotwired.dev)",
      "WebFetch(domain:masilotti.com)",
      "WebFetch(domain:betterspecs.org)",
      "WebFetch(domain:thoughtbot.com)",
      "WebFetch(domain:www.meilisearch.com)",
      "WebFetch(domain:moodledev.io)",
      "WebFetch(domain:docs.sentry.io)",
      "WebFetch(domain:getbootstrap.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:github.blog)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:learn.omacom.io)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:kamal-deploy.org)",
      "WebFetch(domain:mise.en.dev)",
      "WebFetch(domain:mise.jdx.dev)",
      "Read(~/.local/share/mise/installs/ruby/**)",
      "Bash(brew info *)",
      "Bash(pmset -g *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block_dangerous_git.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/allow_commands.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/allow_gem_github.rb"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_chrome-devtools-mcp_chrome-devtools__.*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/allow_chrome_devtools.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rubocop_file.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/markdownlint_file.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/shellcheck_file.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx ccstatusline@latest"
  },
  "enabledPlugins": {
    "codex@openai-codex": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": true,
    "qmd@qmd": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    },
    "qmd": {
      "source": {
        "source": "github",
        "repo": "tobi/qmd"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "*.github.com",
        "objects.githubusercontent.com",
        "codeload.github.com",
        "raw.githubusercontent.com",
        "rubygems.org",
        "index.rubygems.org",
        "pypi.org",
        "files.pythonhosted.org"
      ],
      "allowUnixSockets": [
        "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
      ],
      "allowLocalBinding": true
    },
    "filesystem": {
      "allowWrite": [
        "~/.claude/plugins/data/codex-openai-codex",
        "~/.local/share/mise",
        "~/.cache"
      ]
    },
    "credentials": {
      "envVars": [
        { "name": "GH_TOKEN", "mode": "deny" },
        { "name": "GITHUB_TOKEN", "mode": "deny" }
      ]
    },
    "excludedCommands": ["docker*", "docker-compose*"]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "fullscreen",
  "theme": "dark"
}
