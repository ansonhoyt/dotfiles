{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:developers.openai.com)",
      "WebFetch(domain:google-gemini.github.io)",
      "WebFetch(domain:api.rubyonrails.org)",
      "WebFetch(domain:docs.ruby-lang.org)",
      "WebFetch(domain:rdoc.info)",
      "WebFetch(domain:rubydoc.info)",
      "WebFetch(domain:rubygems.org)",
      "WebFetch(domain:index.rubygems.org)",
      "WebFetch(domain:rubocop.org)",
      "WebFetch(domain:docs.rubocop.org)",
      "WebFetch(domain:rubyweekly.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:hotwired.dev)",
      "WebFetch(domain:hotwire.io)",
      "WebFetch(domain:native.hotwired.dev)",
      "WebFetch(domain:stimulus.hotwired.dev)",
      "WebFetch(domain:turbo.hotwired.dev)",
      "WebFetch(domain:masilotti.com)",
      "WebFetch(domain:betterspecs.org)",
      "WebFetch(domain:thoughtbot.com)",
      "WebFetch(domain:www.meilisearch.com)",
      "WebFetch(domain:moodledev.io)",
      "WebFetch(domain:docs.sentry.io)",
      "WebFetch(domain:getbootstrap.com)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:kamal-deploy.org)",
      "Read(~/.local/share/mise/installs/ruby/**)"
    ]
  },
  "model": "Opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/allow_commands.sh"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/allow_gem_github.rb"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rubocop_file.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/markdownlint_file.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx ccstatusline@latest"
  },
  "enabledPlugins": {
    "codex@openai-codex": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high"
}
