# https://developers.openai.com/codex/rules/

prefix_rule(
  pattern = ["bundle", "update"],
  decision = "allow",
  match = [
    "bundle update",
    "bundle update rails"
  ],
)

prefix_rule(
  pattern = ["bundle", "add"],
  decision = "allow",
  match = [
    "bundle add rails",
    "bundle add foo --group development"
  ],
)

prefix_rule(
  pattern = ["git", "commit", "--amend"],
  decision = "forbidden",
  justification = "Do not amend commits from Codex.",
)

prefix_rule(
  pattern = [["cap", "bin/cap", "./bin/cap"], ["production", "staging"]],
  decision = "forbidden",
  justification = "No Capistrano on production or staging",
)

prefix_rule(
  pattern = ["bundle", "exec", "cap", ["production", "staging"]],
  decision = "forbidden",
  justification = "No Capistrano on production or staging",
)

prefix_rule(
  pattern = ["git", "commit", ["-m", "--message"]],
  decision = "allow",
)

prefix_rule(
  pattern = ["gh", "run", ["list", "view", "watch", "download"]],
  decision = "allow",
  match = [
    "gh run list",
    "gh run view 12345",
    "gh run watch 12345",
    "gh run download 12345"
  ],
)

