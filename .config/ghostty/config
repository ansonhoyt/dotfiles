# Ghostty Config
# https://ghostty.org/docs/config/reference

# Font
font-family = JetBrainsMono Nerd Font Mono
font-size = 12.8

# Shell integration:
# - sudo: preserve terminfo through sudo
# - ssh-env: propagate TERM_PROGRAM, COLORTERM, etc. to remote hosts
# - ssh-terminfo: auto-install xterm-ghostty terminfo on remotes (falls back to xterm-256color if it can't)
shell-integration-features = sudo,ssh-env,ssh-terminfo
keybind = shift+enter=text:\x1b\r
# Let cmd+enter pass through (lazygit commit submit via kitty protocol) instead of toggling fullscreen
keybind = cmd+enter=unbind

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# no titlebar. rounded corners, borders
macos-titlebar-style = hidden
window-padding-balance = true
