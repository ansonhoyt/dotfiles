#!/usr/bin/env bash

# MacOS configuration
#
# @see https://github.com/geerlingguy/dotfiles/blob/master/.osx
#
# @author Anson Hoyt

if [ "$(uname)" = 'Darwin' ]; then
  echo 'Configuring macOS...'
else
  echo 'Not macOS...exiting!'
  exit
fi

###############################################################################
# Trackpad, mouse, keyboard, Bluetooth accessories, and input                 #
###############################################################################

# Disable press-and-hold for keys in favor of key repeat
defaults write NSGlobalDomain ApplePressAndHoldEnabled -bool false

###############################################################################
# Activity Monitor                                                            #
###############################################################################

# Show the main window when launching Activity Monitor
defaults write com.apple.ActivityMonitor OpenMainWindow -bool true

# Set Activity Monitor Dock Icon
# 0: Application Icon
# 2: Network Usage
# 3: Disk Activity
# 5: CPU Usage
# 6: CPU History
defaults write com.apple.ActivityMonitor IconType -int 6

# Show processes in Activity Monitor
# 100: All Processes
# 101: All Processes, Hierarchally
# 102: My Processes
# 103: System Processes
# 104: Other User Processes
# 105: Active Processes
# 106: Inactive Processes
# 107: Windowed Processes
defaults write com.apple.ActivityMonitor ShowCategory -int 100

###############################################################################
# App Store                                                                   #
###############################################################################

# Disable in-app rating requests from apps downloaded from the App Store.
defaults write com.apple.appstore InAppReviewEnabled -int 0

###############################################################################
# Dock                                                                        #
###############################################################################

# Remove unwanted apps from Dock
remove_dock_item() {
  local plist=~/Library/Preferences/com.apple.dock.plist i=0 label
  while label=$(/usr/libexec/PlistBuddy -c "Print persistent-apps:$i:tile-data:file-label" "$plist" 2>/dev/null); do
    [ "$label" = "$1" ] && /usr/libexec/PlistBuddy -c "Delete persistent-apps:$i" "$plist" && return
    ((i++))
  done
  return 1
}

# Keep: Apps, Safari, Messages, Mail, Calendar, App Store, System Settings
dock_changed=0
for app in News TV Maps FaceTime Photos Games "iPhone Mirroring" Notes \
           Phone Contacts Reminders Music Keynote Numbers Pages; do
  remove_dock_item "$app" && dock_changed=1
done
[ "$dock_changed" -eq 1 ] && killall Dock

###############################################################################
# SSH                                                                         #
###############################################################################

# Install authorized_keys BEFORE enabling pubkey-only auth to avoid lockout.
touch ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys

key=$(op read --account my.1password.com "op://Private/Personal ed25519/public key") \
  || { echo "op read failed"; exit 1; }
echo "$key" | ssh-keygen -l -f - >/dev/null 2>&1 \
  || { echo "key from 1Password is not a valid SSH public key"; exit 1; }
grep -qxF "$key" ~/.ssh/authorized_keys || echo "$key" >> ~/.ssh/authorized_keys

# SSH hardening below needs sudo; authenticate up front so a missing
# TTY (e.g. run via a non-interactive shell) fails fast and clearly.
sudo -v || { echo "sudo needs a terminal — run ./.osx in an interactive shell"; exit 1; }

# Enable Remote Login (SSHD). bootstrap is no-op if already loaded.
sudo launchctl enable system/com.openssh.sshd
sudo launchctl bootstrap system /System/Library/LaunchDaemons/ssh.plist 2>/dev/null || true

sudo tee /etc/ssh/sshd_config.d/100-hardening.conf >/dev/null <<'EOF'
AllowGroups admin
PasswordAuthentication no
KbdInteractiveAuthentication no
ChallengeResponseAuthentication no
PubkeyAuthentication yes
MaxAuthTries 3
LoginGraceTime 30
LogLevel VERBOSE
ClientAliveInterval 300
ClientAliveCountMax 2
EOF
sudo ssh-keygen -A 2>/dev/null  # generate host keys if missing (no-op if present)
sudo sshd -t || { echo "sshd config invalid; not reloading"; exit 1; }
sudo launchctl kickstart -k system/com.openssh.sshd

###############################################################################
# Time Machine                                                                #
###############################################################################

# Exclude large/ephemeral dirs. xattr form (no -p) avoids needing FDA, but
# the dir must exist — re-run ./.osx after installing a new tool.
tm_paths=(
  ~/Parallels
  ~/"VirtualBox VMs"
  ~/.vagrant.d
  ~/.lmstudio/models
  ~/.npm
  ~/.gradle
  ~/.m2
  ~/.local/share/mise
  ~/Library/Developer/Xcode/DerivedData
  ~/Library/Developer/CoreSimulator/Devices
  ~/Library/Containers/com.docker.docker/Data
  ~/.docker/sandboxes
  ~/"Library/Application Support/com.apple.container"
)

echo "Configure Time Machine exclusions:"
tm_to_add=()
for path in "${tm_paths[@]}"; do
  if [ ! -e "$path" ]; then
    printf '  \033[2m∅  %s\033[0m\n' "$path"
  elif [[ "$(tmutil isexcluded "$path")" == *"[Excluded"* ]]; then
    printf '  ✅ %s\n' "$path"
  else
    tm_to_add+=("$path")
  fi
done
if [ ${#tm_to_add[@]} -gt 0 ]; then
  tmutil addexclusion "${tm_to_add[@]}"
  for path in "${tm_to_add[@]}"; do
    printf '  ➕ %s\n' "$path"
  done
fi

echo "Done!"
